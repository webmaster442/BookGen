<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <OutputPath>..\..\bin\$(Configuration)\</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Http\ErrorPageTemplate.html" />
    <None Remove="Http\QRCodeTemplate.html" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Http\ErrorPageTemplate.html" />
    <EmbeddedResource Include="Http\QRCodeTemplate.html" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Markdig" Version="0.42.0" />
    <PackageReference Include="System.ServiceModel.Syndication" Version="10.0.0-rc.1.25451.107" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
    <PackageReference Include="SkiaSharp" Version="3.119.0" />
    <PackageReference Include="SkiaSharp.NativeAssets.Linux" Version="3.119.0" />
    <PackageReference Include="SkiaSharp.NativeAssets.Win32" Version="3.119.0" />
    <PackageReference Include="Svg.Skia" Version="3.2.1" />
    <PackageReference Include="Microsoft.ClearScript" Version="7.5.0" />
    <PackageReference Include="Microsoft.ClearScript.V8.Native.linux-x64" Version="7.5.0" />
    <PackageReference Include="Microsoft.ClearScript.V8.Native.win-x64" Version="7.5.0" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Bookgen.Tests" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\BookGen.Shell.Shared\BookGen.Shell.Shared.csproj" />
    <ProjectReference Include="..\BookGen.Vfs\BookGen.Vfs.csproj" />
  </ItemGroup>

</Project>
